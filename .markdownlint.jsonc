{
  // Line length — disabled because tables and blockquotes often exceed 80 chars
  "MD013": false,
  // Multiple top-level headings — example files have # as part of the example output
  "MD025": false,
  // Inline HTML — badges in README use HTML img tags
  "MD033": false,
  // Bare URLs — disabled for flexibility
  "MD034": false,
  // Emphasis used instead of heading — false positives in legal text
  "MD036": false,
  // Duplicate headings — CHANGELOG uses repeated "Added", "Changed" under different versions
  "MD024": false,
  // Fenced code blocks language — prompt examples intentionally have no language
  "MD040": false,
  // Empty links — version badge uses empty link target
  "MD042": false,
  // Table column style — auto-generated tables may have compact style
  "MD060": false
}
